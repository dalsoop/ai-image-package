{
  "meta": {
    "name": "이미지 프롬프트 검증 규칙",
    "version": "1.0.0",
    "description": "7섹션 디렉팅 시트의 이미지 프롬프트 검증. 시간 흐름 감지, 중복 키워드 감지, 섹션 완성도 검사."
  },
  "temporal_keywords": {
    "description": "이미지 프롬프트에 시간 흐름이 있으면 안 됨. 감지 시 영상 전환 권고.",
    "forbidden": [
      "then", "suddenly", "after", "next", "before", "later",
      "eventually", "finally", "meanwhile", "begins to", "starts to",
      "transitions to", "shifts to", "changes to", "turns into",
      "followed by", "moments later", "seconds later",
      "first then", "second then", "third then",
      "from A to B", "gradually", "over time",
      "in sequence", "one by one", "step by step"
    ],
    "allowed_exceptions": [
      "before dawn",
      "after rain",
      "golden hour before sunset",
      "secondary",
      "first person",
      "first view",
      "third person"
    ],
    "action": "reject",
    "message": "시간 흐름 키워드 감지. 이미지는 한 순간만 담아야 합니다. 영상으로 전환하려면 avp를 사용하세요."
  },
  "duplicate_detection": {
    "description": "서로 다른 섹션에서 동일한 키워드가 반복되면 노이즈.",
    "min_word_length": 4,
    "ignore_words": [
      "with", "from", "that", "this", "and", "the", "for",
      "creating", "detailed", "style", "anime", "light", "lighting",
      "color", "subtle", "soft", "deep", "high", "space", "character",
      "hair", "eyes", "face", "body", "skin", "helmet", "suit",
      "cosmic", "camera", "scene", "background", "realistic", "accurate",
      "visual", "surface", "elements", "floating", "blue", "white", "dark",
      "warm", "cold", "cool", "bright", "glow", "glowing"
    ],
    "threshold": 3,
    "action": "warn",
    "message": "중복 키워드 감지. 섹션 간 역할 분리를 권장합니다."
  },
  "sections": {
    "description": "7섹션 완성도 검사",
    "required": [
      {
        "name": "Style",
        "marker": "## Style",
        "min_length": 50,
        "purpose": "전체 화풍/톤 정의",
        "forbidden_patterns": []
      },
      {
        "name": "Composition",
        "marker": "## Composition",
        "min_length": 50,
        "purpose": "구도/배치/프레이밍",
        "forbidden_patterns": []
      },
      {
        "name": "Character Details",
        "marker": "## Character Details",
        "min_length": 50,
        "purpose": "캐릭터 외형/의상/표정",
        "forbidden_patterns": []
      },
      {
        "name": "Environmental Elements",
        "marker": "## Environmental Elements",
        "min_length": 30,
        "purpose": "환경/배경 디테일",
        "forbidden_patterns": []
      },
      {
        "name": "Action Elements",
        "marker": "## Action Elements",
        "min_length": 30,
        "purpose": "동작/포즈 (한 순간만)",
        "forbidden_patterns": ["temporal_keywords"]
      },
      {
        "name": "Lighting & Atmosphere",
        "marker": "## Lighting & Atmosphere",
        "min_length": 30,
        "purpose": "조명/분위기",
        "forbidden_patterns": []
      },
      {
        "name": "Technical Details",
        "marker": "## Technical Details",
        "min_length": 30,
        "purpose": "렌더링/퀄리티 수준",
        "forbidden_patterns": []
      }
    ]
  },
  "classification": {
    "description": "이미지 vs 영상 자동 분류",
    "image_indicators": [
      "single moment", "frozen", "still", "captured", "portrait",
      "poster", "sheet", "concept art", "key visual"
    ],
    "video_indicators": [
      "sequence", "animation", "movement over time", "continuous",
      "transitions", "camera follows", "tracking shot"
    ],
    "temporal_found_action": "suggest_video",
    "message": "이 프롬프트는 영상에 더 적합합니다. avp로 타임라인을 분할하세요."
  }
}
